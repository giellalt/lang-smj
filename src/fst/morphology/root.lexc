! =================================================
! Basic lexica, pointing to the other lexicon files
! =================================================

LEXICON Root
!! # Lexicon `@LEXNAME@`

!! The beginning of everything. Every FST defined in LexC must start with the
!! reserved lexicon name `@LEXNAME@`.

 @U.Cap.Obl@ ProperNoun          ;
 @U.Cap.Opt@ ProperNoun          ;
             Prefixes            ;
             NounRoot            ;
!            ProperNounFirstPart ;
             Adjective           ;
             Verb                ;
             Adverb              ;
             Particle            ;
             Subjunction         ;
             Conjunction         ;
             Adposition          ;
!            Postposition        ;
!            Preposition         ;
             Interjection        ;
             Pronoun             ;
 +Use/CircN: Numeral             ;
             Acronym             ;
             Abbreviation        ;
             Punctuation         ;
             Symbols             ;
             telephones          ;

LEXICON Abbreviation
Abbreviation-smj ;
Abbreviation-smi ;




LEXICON Acronym   !!вүҲ * **@CODE@**
Acronym-smi ;
Acronym-smj ;



LEXICON ProperNoun   !!вүҲ * **@CODE@**
  @U.CmpHyph.TRUE@ ProperNoun-smj-nocomp ; ! Lexicon for SMJ short names - always require hyphen
  @U.CmpHyph.TRUE@ ProperNoun-smi-nocomp ; ! Lexicon for short names - always require hyphen
! @U.CmpHyph.TRUE@ ProperNoun-sma-nocomp ; ! Lexicon for SME short names - always require hyphen
! @U.CmpHyph.TRUE@ ProperNoun-sme-nocomp ; ! Lexicon for SMA short names - always require hyphen
                   ProperNoun-smi        ; ! SMI proper nouns
!                  ProperNoun-sma        ; ! SMA proper nouns
!                  ProperNoun-sme        ; ! SME proper nouns
                   OLang/NOB             ;
                   OLang/PARA            ;
                   OLang/SMS             ;
                   OLang/SME             ;
                   UNASS-SM              ;
                   UNASS-SME             ;
                   ERR/ORTH              ;
                   ProperNoun-smj        ; ! contains the full smj name list
       @U.Cap.Obl@ FirstComponentProper  ; ! Short forms



LEXICON ENDLEX
!! # Lexicon @LEXNAME@
!! And this is the @LEXNAME@ of everything:
!! ```
   @D.CmpOnly.FALSE@@D.CmpPref.TRUE@@D.NeedNoun.ON@ ENDLEX2 ; !!вүҲ @CODE@
!! ```
!! The `@D.CmpOnly.FALSE@` flag diacritic is ued to disallow words tagged
!! with +CmpNP/Only to end here.
!! The `@D.NeedNoun.ON@` flag diacritic is used to block illegal compounds.

