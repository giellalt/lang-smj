{
    "analyser": "@abs_builddir@/../../analyser-gt-norm.hfstol",
    "generator": "@abs_builddir@/../../generator-gt-norm.hfstol",
    "nouns": {
        "lexcfile": "@abs_srcdir@/../stems/nouns.lexc",
        "lemmatags": ["+N+Sg+Nom", "+N+Pl+Nom"],
        "exclusions": ["(ShCmp|RCmpnd|ÅLLAGASJ|CmpN/Only|Err/Der|Err/Lex|Use/MT|Use/-Spell|CmpNP/Suff|CmpNP/Pref|Err/Cmp)"]
    },
    "adjectives": {
        "lexcfile": "@abs_srcdir@/../stems/adjectives.lexc",
        "lemmatags": ["+A+Sg+Nom"]
    },
    "propernouns": {
        "lexcfile": "@abs_srcdir@/../stems/smj-propernouns.lexc",
        "lemmatags": ["+N+Prop+Sg+Nom", "+N+Prop+Pl+Nom", "+N+Prop+Attr"],
        "exclusions": ["(Use/-Spell)"]
    },
    "verbs": {
        "lexcfile": "@abs_srcdir@/../stems/verbs.lexc",
        "lemmatags": ["+V+Inf"],
        "exclusions": ["(\\+Neg|STRAYFORMS|\\+Use/MT|Err/Lex|ShCmp|RCmpnd|CmpN/Only|Err/Cmp)"]
    }
}
